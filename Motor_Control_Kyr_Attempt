//  Key improvements over previous versions:
//    1. Motion overlap — Z and XY move simultaneously at 3 points
//       in the cycle, hiding Z travel time behind arm transit.
//    2. Two-stage homing on all axes (fast approach → back-off →
//       slow re-approach) with debounced switches and timeouts.
//    3. Non-blocking camera input — steppers never starved.
//    4. Coordinated XY — slower joint scales to match the faster
//       one, so both joints always arrive at the same time.
//    5. Nearest-branch IK — picks whichever elbow solution
//       requires less total joint travel.
//    6. Workspace pre-validation before committing to a move.
//    7. Stability tracker reset between cycles (static var bug fix).
//    8. Debounced limit switch reads during homing.
//
//  Motion overlap summary:
//    STATE_APPROACH        XY → disc      AND  Z → approach height
//    STATE_PICKUP_ASCEND   Z rising; XY → dropoff starts at Z_CLEAR_HEIGHT
//    STATE_DELIVER_TRANSIT XY finishing   AND  Z → travel height
//    STATE_RETURN_ASCEND   Z rising; XY → home starts at Z_CLEAR_HEIGHT
//    STATE_RETURN_HOME     XY finishing   AND  Z → observe height
// ============================================================

#include <AccelStepper.h>
#include <HardwareSerial.h>
#include "driver/ledc.h"
#include <math.h>

// ─────────────────────────────────────────
//  HARDWARE PINS  (Document 2 mapping)
// ─────────────────────────────────────────
#define M1_STEP_PIN  4       // Z axis stepper
#define M1_DIR_PIN   5
#define LIMIT_PIN_Z  7       // Z bottom limit switch

#define M2_STEP_PIN  42      // Shoulder stepper
#define M2_DIR_PIN   41

#define M3_STEP_PIN  15      // Elbow stepper
#define M3_DIR_PIN   16

#define LIMIT_PIN_XY 6       // Shared XY limit switch (mounted on SCARA body)
#define SERVO_PIN    40      // Gripper servo (LEDC PWM)

HardwareSerial CameraSerial(2);  // RX = pin 17, TX = pin 18

#define MOTOR_INTERFACE_TYPE 1
AccelStepper stepper1(MOTOR_INTERFACE_TYPE, M1_STEP_PIN, M1_DIR_PIN);  // Z
AccelStepper stepper2(MOTOR_INTERFACE_TYPE, M2_STEP_PIN, M2_DIR_PIN);  // Shoulder
AccelStepper stepper3(MOTOR_INTERFACE_TYPE, M3_STEP_PIN, M3_DIR_PIN);  // Elbow

// ─────────────────────────────────────────
//  STATE MACHINE
// ─────────────────────────────────────────
enum RobotState {
  STATE_IDLE,

  // Locate
  STATE_LOCATING_DISC,         // Camera scanning; arm at observe position

  // Pickup
  STATE_APPROACH,              // [OVERLAP] XY → disc position AND Z → approach height
  STATE_PICKUP_DESCEND,        // Z slow final descent to disc level
  STATE_PICKUP_CLOSE,          // Gripper closes — timed settle

  // Pickup → Deliver transition (overlap trigger)
  STATE_PICKUP_ASCEND,         // Z rising; XY → dropoff fires once Z clears safe height

  // Deliver
  STATE_DELIVER_TRANSIT,       // [OVERLAP] XY finishing to dropoff AND Z to travel height
  STATE_DELIVER_DESCEND_FAST,  // Z fast descent to dropoff approach height
  STATE_DELIVER_DESCEND_SLOW,  // Z slow final descent at dropoff
  STATE_DELIVER_OPEN,          // Gripper opens — timed settle

  // Return (overlap trigger)
  STATE_RETURN_ASCEND,         // Z rising; XY → home fires once Z clears safe height
  STATE_RETURN_HOME,           // [OVERLAP] XY finishing to home AND Z to observe height
};

RobotState    currentState = STATE_IDLE;
unsigned long stateTimer   = 0;

// ─────────────────────────────────────────
//  CAMERA BUFFER  (non-blocking)
// ─────────────────────────────────────────
String cameraLine      = "";
bool   cameraLineReady = false;

// ─────────────────────────────────────────
//  ROBOT GEOMETRY
// ─────────────────────────────────────────
const float L1 = 110.0f;   // Shoulder-to-elbow length (mm)
const float L2 = 130.0f;   // Elbow-to-EE length (mm)

// True mathematical angles when the shared XY limit switch fires.
// All subsequent positions are computed relative to this known pose.
const float THETA1_HOME_DEG = 290.0f;
const float THETA2_HOME_DEG =  60.0f;

// Physical joint limits
// Theta1 expressed in 0-360° convention; Theta2 in ±180°.
const float THETA1_MIN_DEG =  90.0f;
const float THETA1_MAX_DEG = 290.0f;
const float THETA2_MIN_DEG = -140.0f;
const float THETA2_MAX_DEG =  140.0f;

// ─────────────────────────────────────────
//  MOTOR SCALING & DIRECTIONS
// ─────────────────────────────────────────
// 1.8° stepper, 8× microstepping, 4:1 gear ratio
const float STEPS_PER_DEG = (200.0f * 8.0f * 4.0f) / 360.0f;

// Sign convention matching Document 2:
//   Shoulder positive = anticlockwise  →  SHOULDER_DIR = +1
//   Elbow    positive = clockwise      →  ELBOW_DIR    = -1
const float SHOULDER_DIR = +1.0f;
const float ELBOW_DIR    = -1.0f;

// Signs for homing moves (direction toward each limit switch)
const float Z_HOME_DIR        = -1.0f;   // Negative = downward toward Z switch
const float SHOULDER_HOME_DIR = +1.0f;   // Matches Document 2 homing speed sign
const float ELBOW_HOME_DIR    = -1.0f;   // Matches Document 2 homing speed sign

// ─────────────────────────────────────────
//  SPEEDS & ACCELERATIONS
// ─────────────────────────────────────────
// Z
const float Z_SPEED_FAST   = 1200.0f;
const float Z_ACCEL_FAST   = 1000.0f;
const float Z_SPEED_SLOW   =  350.0f;
const float Z_ACCEL_SLOW   =  500.0f;

// XY — base values; slower axis is scaled down to match the faster
const float SH_MAX_SPEED   = 1800.0f;
const float SH_MAX_ACCEL   = 1200.0f;
const float EL_MAX_SPEED   = 1800.0f;
const float EL_MAX_ACCEL   = 1000.0f;
const float XY_MIN_SPEED   =  350.0f;   // Never let the scaled axis drop below this
const float XY_MIN_ACCEL   =  250.0f;

// Homing
const float HOME_Z_FAST    =  700.0f;
const float HOME_Z_SLOW    =  180.0f;
const float HOME_SH_FAST   =  700.0f;
const float HOME_SH_SLOW   =  180.0f;
const float HOME_EL_FAST   =  500.0f;
const float HOME_EL_SLOW   =  140.0f;

const long  BACKOFF_Z      = 120;
const long  BACKOFF_SH     = 120;
const long  BACKOFF_EL     = 120;

const unsigned long HOME_TIMEOUT_MS = 12000;

// ─────────────────────────────────────────
//  HEIGHTS & POSITIONS
// ─────────────────────────────────────────
// Z positions in steps above the bottom limit switch (positive = up).
// Zero = Z home switch trigger point.
const long Z_OBSERVE_HEIGHT   = 500;   // Camera observation position
const long Z_DISC_APPROACH    =  30;   // Fast Z descent stops here; slow takes over
const long Z_DISC_LEVEL       =   0;   // TODO: calibrate to actual disc surface height
const long Z_TRAVEL_HEIGHT    = 220;   // Clearance for full arm sweep
const long Z_CLEAR_HEIGHT     =  80;   // Min Z before XY motion is safe to start
const long Z_DROPOFF_APPROACH =  70;   // Fast Z descent stops here at dropoff
const long Z_DROPOFF_LEVEL    =  40;   // TODO: calibrate to actual dropoff surface

// XY Cartesian targets (mm)
const float DROPOFF_X = -148.0f;   // TODO: measure and update with actual dropoff coordinates
const float DROPOFF_Y =  190.0f;

const unsigned long GRIPPER_SETTLE_MS = 200;  // Time to wait after open/close command

// ─────────────────────────────────────────
//  CAMERA CALIBRATION (2D similarity transform)
// ─────────────────────────────────────────
const float CAM_P1 = 0.907631f;      // k*cos(theta)
const float CAM_P2 = -0.017293f;     // k*sin(theta)
const float CAM_TX = -259.497903f;   // Translation X (mm)
const float CAM_TY = -140.493713f;   // Translation Y (mm)

// ─────────────────────────────────────────
//  FORWARD DECLARATIONS
// ─────────────────────────────────────────
void  transitionTo(RobotState s);
bool  motorsIdle(bool z, bool sh, bool el);
bool  moveToPos(float x, float y);
void  moveZFast(long target);
void  moveZSlow(long target);
void  moveArmJointsCoordinated(long target2, long target3);
void  openGripper();
void  closeGripper();
void  updateCameraBuffer();
void  handleLocatingDisc();
void  resetStabilityTracker();
bool  homeRobot();
bool  readLimitDebounced(int pin, int samples, unsigned long delayUs);
float normalize360(float a);
float normalize180(float a);
float angleDiffDeg(float a, float b);
bool  checkLimits(float t1, float t2);
long  shoulderAngleToSteps(float deg);
long  elbowAngleToSteps(float deg);
float currentTheta1Deg();
float currentTheta2Deg();

// ─────────────────────────────────────────
//  SETUP
// ─────────────────────────────────────────
void setup() {
  Serial.begin(115200);
  Serial.println("SCARA v3 starting...");

  pinMode(LIMIT_PIN_Z,  INPUT_PULLUP);
  pinMode(LIMIT_PIN_XY, INPUT_PULLUP);

  // ESP32 can pulse faster than some drivers handle — keep min pulse width
  stepper1.setMinPulseWidth(20);
  stepper2.setMinPulseWidth(20);
  stepper3.setMinPulseWidth(20);

  stepper1.setMaxSpeed(Z_SPEED_FAST);  stepper1.setAcceleration(Z_ACCEL_FAST);
  stepper2.setMaxSpeed(SH_MAX_SPEED);  stepper2.setAcceleration(SH_MAX_ACCEL);
  stepper3.setMaxSpeed(EL_MAX_SPEED);  stepper3.setAcceleration(EL_MAX_ACCEL);

  // Servo: 50 Hz PWM, 16-bit resolution
  ledcAttach(SERVO_PIN, 50, 16);
  openGripper();

  CameraSerial.begin(9600, SERIAL_8N1, 17, 18);

  if (!homeRobot()) {
    Serial.println("FATAL: Homing failed. System halted.");
    while (true) {}
  }

  moveZFast(Z_OBSERVE_HEIGHT);
  transitionTo(STATE_LOCATING_DISC);
}

// ─────────────────────────────────────────
//  MAIN LOOP
// ─────────────────────────────────────────
// No blocking calls or while-loops here — stepper.run() must execute
// every iteration to generate step pulses at the right frequency.
void loop() {
  stepper1.run();
  stepper2.run();
  stepper3.run();

  updateCameraBuffer();

  switch (currentState) {

    // ── IDLE ──────────────────────────────────────────────────
    case STATE_IDLE:
      break;

    // ── LOCATE ────────────────────────────────────────────────
    case STATE_LOCATING_DISC:
      handleLocatingDisc();
      break;

    // ── APPROACH  [OVERLAP: XY + Z simultaneously] ────────────
    // XY moves toward the disc while Z descends fast to approach
    // height. Both must finish before the final slow descent.
    case STATE_APPROACH:
      if (motorsIdle(true, true, true)) {
        moveZSlow(Z_DISC_LEVEL);
        transitionTo(STATE_PICKUP_DESCEND);
      }
      break;

    // ── PICKUP DESCEND ────────────────────────────────────────
    case STATE_PICKUP_DESCEND:
      if (motorsIdle(true, false, false)) {
        closeGripper();
        stateTimer = millis();
        transitionTo(STATE_PICKUP_CLOSE);
      }
      break;

    // ── PICKUP CLOSE (timed) ──────────────────────────────────
    case STATE_PICKUP_CLOSE:
      if (millis() - stateTimer >= GRIPPER_SETTLE_MS) {
        moveZFast(Z_TRAVEL_HEIGHT);
        transitionTo(STATE_PICKUP_ASCEND);
      }
      break;

    // ── PICKUP ASCEND  [OVERLAP TRIGGER] ──────────────────────
    // Z is climbing from disc level toward travel height.
    // The instant it clears Z_CLEAR_HEIGHT (arm is safely above
    // any obstacle), we issue the XY move to the dropoff position.
    // This hides almost the entire XY transit inside the Z ascent.
    case STATE_PICKUP_ASCEND:
      if (stepper1.currentPosition() >= Z_CLEAR_HEIGHT && motorsIdle(false, true, true)) {
        if (moveToPos(DROPOFF_X, DROPOFF_Y)) {
          transitionTo(STATE_DELIVER_TRANSIT);
        } else {
          Serial.println("ERROR: Dropoff XY unreachable — check DROPOFF_X/Y constants");
          transitionTo(STATE_IDLE);
        }
      }
      break;

    // ── DELIVER TRANSIT  [OVERLAP: XY + Z simultaneously] ─────
    // Z is still climbing to full travel height; XY is heading to
    // the dropoff. Wait for both before beginning the descent.
    case STATE_DELIVER_TRANSIT:
      if (motorsIdle(true, true, true)) {
        moveZFast(Z_DROPOFF_APPROACH);
        transitionTo(STATE_DELIVER_DESCEND_FAST);
      }
      break;

    // ── DELIVER DESCEND FAST ──────────────────────────────────
    case STATE_DELIVER_DESCEND_FAST:
      if (motorsIdle(true, false, false)) {
        moveZSlow(Z_DROPOFF_LEVEL);
        transitionTo(STATE_DELIVER_DESCEND_SLOW);
      }
      break;

    // ── DELIVER DESCEND SLOW ──────────────────────────────────
    case STATE_DELIVER_DESCEND_SLOW:
      if (motorsIdle(true, false, false)) {
        openGripper();
        stateTimer = millis();
        transitionTo(STATE_DELIVER_OPEN);
      }
      break;

    // ── DELIVER OPEN (timed) ──────────────────────────────────
    case STATE_DELIVER_OPEN:
      if (millis() - stateTimer >= GRIPPER_SETTLE_MS) {
        // Head straight to observe height — no intermediate stop needed
        moveZFast(Z_OBSERVE_HEIGHT);
        transitionTo(STATE_RETURN_ASCEND);
      }
      break;

    // ── RETURN ASCEND  [OVERLAP TRIGGER] ──────────────────────
    // Mirror of PICKUP_ASCEND. Z climbs from dropoff level toward
    // observe height. Once it clears the safe threshold, XY starts
    // returning to the home/observe position simultaneously.
    case STATE_RETURN_ASCEND:
      if (stepper1.currentPosition() >= Z_CLEAR_HEIGHT && motorsIdle(false, true, true)) {
        long home2 = shoulderAngleToSteps(THETA1_HOME_DEG);
        long home3 = elbowAngleToSteps(THETA2_HOME_DEG);
        moveArmJointsCoordinated(home2, home3);
        transitionTo(STATE_RETURN_HOME);
      }
      break;

    // ── RETURN HOME  [OVERLAP: XY + Z simultaneously] ─────────
    // XY finishes back to home; Z finishes to observe height.
    // Reset stability tracker so the next disc search starts fresh.
    case STATE_RETURN_HOME:
      if (motorsIdle(true, true, true)) {
        resetStabilityTracker();
        transitionTo(STATE_LOCATING_DISC);
      }
      break;
  }
}

// ─────────────────────────────────────────
//  STATE HELPERS
// ─────────────────────────────────────────
void transitionTo(RobotState s) {
  Serial.printf("[STATE] %d -> %d\n", (int)currentState, (int)s);
  currentState = s;
}

bool motorsIdle(bool checkZ, bool checkShoulder, bool checkElbow) {
  if (checkZ        && stepper1.distanceToGo() != 0) return false;
  if (checkShoulder && stepper2.distanceToGo() != 0) return false;
  if (checkElbow    && stepper3.distanceToGo() != 0) return false;
  return true;
}

// ─────────────────────────────────────────
//  GRIPPER  (LEDC direct PWM)
// ─────────────────────────────────────────
void writeServoUs(int us) {
  // 16-bit LEDC at 50 Hz: period = 20 000 µs = 65 536 ticks
  ledcWrite(SERVO_PIN, (uint32_t)us * 65536 / 20000);
}

void closeGripper() { writeServoUs(2400); }
void openGripper()  { writeServoUs(500);  }

// ─────────────────────────────────────────
//  STEP ↔ ANGLE CONVERSIONS
// ─────────────────────────────────────────
// Steps directly encode the mathematical angle, matching Document 2's convention:
//   stepper2 position = SHOULDER_DIR * angle_deg * STEPS_PER_DEG
//   stepper3 position = ELBOW_DIR    * angle_deg * STEPS_PER_DEG

long shoulderAngleToSteps(float deg) {
  return lround(SHOULDER_DIR * deg * STEPS_PER_DEG);
}

long elbowAngleToSteps(float deg) {
  return lround(ELBOW_DIR * deg * STEPS_PER_DEG);
}

float currentTheta1Deg() {
  return stepper2.currentPosition() / (SHOULDER_DIR * STEPS_PER_DEG);
}

float currentTheta2Deg() {
  return stepper3.currentPosition() / (ELBOW_DIR * STEPS_PER_DEG);
}

// ─────────────────────────────────────────
//  MATH HELPERS
// ─────────────────────────────────────────
float normalize360(float a) {
  while (a <    0.0f) a += 360.0f;
  while (a >= 360.0f) a -= 360.0f;
  return a;
}

float normalize180(float a) {
  while (a >   180.0f) a -= 360.0f;
  while (a <= -180.0f) a += 360.0f;
  return a;
}

// Minimum arc between two angles — handles 360° wraparound correctly
float angleDiffDeg(float a, float b) {
  return fabsf(normalize180(a - b));
}

bool checkLimits(float t1, float t2) {
  return (t1 >= THETA1_MIN_DEG && t1 <= THETA1_MAX_DEG &&
          t2 >= THETA2_MIN_DEG && t2 <= THETA2_MAX_DEG);
}

// ─────────────────────────────────────────
//  LIMIT SWITCH DEBOUNCE
// ─────────────────────────────────────────
// Reads the switch multiple times to reject electrical noise.
// Returns true only if all samples read LOW (triggered).
bool readLimitDebounced(int pin, int samples = 4, unsigned long delayUs = 500) {
  for (int i = 0; i < samples; i++) {
    if (digitalRead(pin) == HIGH) return false;
    delayMicroseconds(delayUs);
  }
  return true;
}

// ─────────────────────────────────────────
//  COORDINATED XY MOTION
// ─────────────────────────────────────────
// The axis with the larger step distance runs at full speed.
// The other axis is scaled proportionally so both arrive together.
// This avoids one joint sitting idle while the other catches up.
void moveArmJointsCoordinated(long target2, long target3) {
  long d2 = labs(target2 - stepper2.currentPosition());
  long d3 = labs(target3 - stepper3.currentPosition());

  if (d2 == 0 && d3 == 0) return;

  if (d2 >= d3) {
    // Shoulder is the master (longer move)
    float ratio = (d2 > 0 && d3 > 0) ? (float)d3 / (float)d2 : 0.0f;
    stepper2.setMaxSpeed(SH_MAX_SPEED);
    stepper2.setAcceleration(SH_MAX_ACCEL);
    stepper3.setMaxSpeed(max(XY_MIN_SPEED, EL_MAX_SPEED * ratio));
    stepper3.setAcceleration(max(XY_MIN_ACCEL, EL_MAX_ACCEL * ratio));
  } else {
    // Elbow is the master (longer move)
    float ratio = (d3 > 0 && d2 > 0) ? (float)d2 / (float)d3 : 0.0f;
    stepper3.setMaxSpeed(EL_MAX_SPEED);
    stepper3.setAcceleration(EL_MAX_ACCEL);
    stepper2.setMaxSpeed(max(XY_MIN_SPEED, SH_MAX_SPEED * ratio));
    stepper2.setAcceleration(max(XY_MIN_ACCEL, SH_MAX_ACCEL * ratio));
  }

  stepper2.moveTo(target2);
  stepper3.moveTo(target3);

  Serial.printf("[XY] Shoulder steps: %ld  Elbow steps: %ld\n", target2, target3);
}

// ─────────────────────────────────────────
//  Z MOTION HELPERS
// ─────────────────────────────────────────
void moveZFast(long target) {
  stepper1.setMaxSpeed(Z_SPEED_FAST);
  stepper1.setAcceleration(Z_ACCEL_FAST);
  stepper1.moveTo(target);
}

void moveZSlow(long target) {
  stepper1.setMaxSpeed(Z_SPEED_SLOW);
  stepper1.setAcceleration(Z_ACCEL_SLOW);
  stepper1.moveTo(target);
}

// ─────────────────────────────────────────
//  INVERSE KINEMATICS
// ─────────────────────────────────────────
// Solves for both elbow-up (A) and elbow-down (B) solutions.
// If both are within joint limits, picks whichever requires the
// least total joint travel from the current pose — minimising
// motion time and reducing wear.
bool moveToPos(float x, float y) {
  float r_sq = x*x + y*y;
  float r    = sqrtf(r_sq);

  if (r > (L1 + L2))      { Serial.println("IK: target out of reach");  return false; }
  if (r < fabsf(L1 - L2)) { Serial.println("IK: target too close");     return false; }

  float cos2 = constrain((r_sq - L1*L1 - L2*L2) / (2.0f * L1 * L2), -1.0f, 1.0f);

  // Solution A — positive elbow angle (elbow out one way)
  float s2A   = acosf(cos2);
  float t1A   = atan2f(y, x) - atan2f(L2 * sinf(s2A), L1 + L2 * cosf(s2A));
  float t1A_d = normalize360(t1A * 180.0f / PI);   // Theta1 in 0-360°
  float t2A_d = normalize180(s2A * 180.0f / PI);   // Theta2 in ±180°

  // Solution B — negative elbow angle (elbow out the other way)
  float s2B   = -acosf(cos2);
  float t1B   = atan2f(y, x) - atan2f(L2 * sinf(s2B), L1 + L2 * cosf(s2B));
  float t1B_d = normalize360(t1B * 180.0f / PI);
  float t2B_d = normalize180(s2B * 180.0f / PI);

  bool validA = checkLimits(t1A_d, t2A_d);
  bool validB = checkLimits(t1B_d, t2B_d);

  float final_t1, final_t2;

  if (validA && validB) {
    // Both branches reachable — pick the closer one
    float curT1 = currentTheta1Deg();
    float curT2 = currentTheta2Deg();
    float distA = angleDiffDeg(t1A_d, curT1) + angleDiffDeg(t2A_d, curT2);
    float distB = angleDiffDeg(t1B_d, curT1) + angleDiffDeg(t2B_d, curT2);
    if (distA <= distB) { final_t1 = t1A_d; final_t2 = t2A_d; Serial.println("IK: branch A"); }
    else                { final_t1 = t1B_d; final_t2 = t2B_d; Serial.println("IK: branch B"); }
  } else if (validA) {
    final_t1 = t1A_d; final_t2 = t2A_d;
    Serial.println("IK: only A valid");
  } else if (validB) {
    final_t1 = t1B_d; final_t2 = t2B_d;
    Serial.println("IK: only B valid");
  } else {
    Serial.println("IK: unsolvable within joint limits");
    return false;
  }

  long steps2 = shoulderAngleToSteps(final_t1);
  long steps3 = elbowAngleToSteps(final_t2);
  moveArmJointsCoordinated(steps2, steps3);

  Serial.printf("IK: shoulder=%.2f°  elbow=%.2f°\n", final_t1, final_t2);
  return true;
}

// ─────────────────────────────────────────
//  CAMERA — NON-BLOCKING BUFFER
// ─────────────────────────────────────────
// Reads one character per loop iteration. Never blocks stepper calls.
// (Document 2 used readStringUntil() which could block for ~20ms
//  and cause missed steps — this approach eliminates that problem.)
void updateCameraBuffer() {
  while (CameraSerial.available()) {
    char c = (char)CameraSerial.read();

    if (c == '\n') {
      cameraLine.trim();
      cameraLineReady = (cameraLine.length() > 0);
      return;
    }
    if (c != '\r') {
      cameraLine += c;
      if (cameraLine.length() > 64) cameraLine = "";  // Guard against runaway input
    }
  }
}

void calculateDiscLocation(float px, float py, float &wx, float &wy) {
  wx = (CAM_P1 * px) - (CAM_P2 * py) + CAM_TX;
  wy = (CAM_P2 * px) + (CAM_P1 * py) + CAM_TY;
}

// Returns true once N consecutive readings are within 1 mm of each other.
// Uses static variables — call resetStabilityTracker() between cycles.
bool areValuesStable(float x, float y) {
  static float lastX     = 1e9f;
  static float lastY     = 1e9f;
  static int   count     = 0;
  const  int   REQUIRED  = 5;   // Consecutive stable readings needed

  if (fabsf(x - lastX) < 1.0f && fabsf(y - lastY) < 1.0f) {
    count++;
  } else {
    lastX = x; lastY = y;
    count = 1;
  }

  if (count >= REQUIRED) { count = 0; return true; }
  return false;
}

// Reset the stability tracker at the start of each new locate cycle.
// Without this, stale count from the previous disc could cause an
// immediate spurious trigger on the first reading of the next cycle.
void resetStabilityTracker() {
  areValuesStable(1e9f, 1e9f);  // Value guaranteed to differ from any real coordinate
}

void handleLocatingDisc() {
  if (!cameraLineReady) return;

  String line     = cameraLine;
  cameraLine      = "";
  cameraLineReady = false;

  if (line == "NONE") return;

  int   px = 0, py = 0;
  float wx = 0, wy = 0;

  if (sscanf(line.c_str(), "X:%d,Y:%d", &px, &py) != 2) return;

  calculateDiscLocation((float)px, (float)py, wx, wy);

  // Pre-validate workspace before even checking stability.
  // Rejects camera outliers before they can contaminate the stable counter.
  float r = sqrtf(wx*wx + wy*wy);
  if (r > (L1 + L2) || r < fabsf(L1 - L2)) {
    Serial.printf("Disc at (%.1f, %.1f) outside workspace — ignored\n", wx, wy);
    return;
  }

  Serial.printf("Disc candidate: (%.1f, %.1f) mm\n", wx, wy);

  if (areValuesStable(wx, wy)) {
    Serial.printf("Disc confirmed — moving to: (%.1f, %.1f) mm\n", wx, wy);

    // ── FIRST OVERLAP POINT ──
    // Issue XY move to disc position AND start Z descending
    // to approach height at the same time. Both travel simultaneously.
    if (moveToPos(wx, wy)) {
      moveZFast(Z_DISC_APPROACH);
      transitionTo(STATE_APPROACH);
    }
  }
}

// ─────────────────────────────────────────
//  HOMING
// ─────────────────────────────────────────
// Each axis uses two-stage homing:
//   1. Fast approach until limit switch triggers (debounced)
//   2. Back off a fixed number of steps
//   3. Slow re-approach until switch triggers again
//   4. Set that position as the axis origin
// This gives consistent, repeatable home positions regardless of
// approach speed variations or switch hysteresis.

bool runToTarget(AccelStepper &m, unsigned long timeout, const char *name) {
  unsigned long t0 = millis();
  while (m.distanceToGo() != 0) {
    m.run();
    if (millis() - t0 > timeout) {
      Serial.printf("[HOME] TIMEOUT: %s\n", name);
      return false;
    }
  }
  return true;
}

bool homeZTwoStage() {
  unsigned long t0;

  Serial.println("[HOME] Z fast approach...");
  stepper1.setSpeed(Z_HOME_DIR * HOME_Z_FAST);
  t0 = millis();
  while (!readLimitDebounced(LIMIT_PIN_Z)) {
    stepper1.runSpeed();
    if (millis() - t0 > HOME_TIMEOUT_MS) { Serial.println("[HOME] Z fast timeout"); return false; }
  }

  stepper1.setCurrentPosition(0);
  long backoff = (Z_HOME_DIR > 0.0f) ? -BACKOFF_Z : BACKOFF_Z;
  stepper1.moveTo(backoff);
  if (!runToTarget(stepper1, HOME_TIMEOUT_MS, "Z backoff")) return false;

  Serial.println("[HOME] Z slow re-approach...");
  stepper1.setSpeed(Z_HOME_DIR * HOME_Z_SLOW);
  t0 = millis();
  while (!readLimitDebounced(LIMIT_PIN_Z)) {
    stepper1.runSpeed();
    if (millis() - t0 > HOME_TIMEOUT_MS) { Serial.println("[HOME] Z slow timeout"); return false; }
  }

  stepper1.setCurrentPosition(0);
  Serial.println("[HOME] Z done.");
  return true;
}

bool homeXYTwoStage() {
  unsigned long t0;

  // Both joints move simultaneously toward the shared XY switch
  Serial.println("[HOME] XY fast approach...");
  stepper2.setSpeed(SHOULDER_HOME_DIR * HOME_SH_FAST);
  stepper3.setSpeed(ELBOW_HOME_DIR    * HOME_EL_FAST);
  t0 = millis();
  while (!readLimitDebounced(LIMIT_PIN_XY)) {
    stepper2.runSpeed();
    stepper3.runSpeed();
    if (millis() - t0 > HOME_TIMEOUT_MS) { Serial.println("[HOME] XY fast timeout"); return false; }
  }

  stepper2.setCurrentPosition(0);
  stepper3.setCurrentPosition(0);

  // Back off both joints
  long sh_back = (SHOULDER_HOME_DIR > 0.0f) ? -BACKOFF_SH : BACKOFF_SH;
  long el_back = (ELBOW_HOME_DIR    > 0.0f) ? -BACKOFF_EL : BACKOFF_EL;
  stepper2.moveTo(sh_back);
  stepper3.moveTo(el_back);

  unsigned long t1 = millis();
  while (stepper2.distanceToGo() != 0 || stepper3.distanceToGo() != 0) {
    stepper2.run(); stepper3.run();
    if (millis() - t1 > HOME_TIMEOUT_MS) { Serial.println("[HOME] XY backoff timeout"); return false; }
  }

  Serial.println("[HOME] XY slow re-approach...");
  stepper2.setSpeed(SHOULDER_HOME_DIR * HOME_SH_SLOW);
  stepper3.setSpeed(ELBOW_HOME_DIR    * HOME_EL_SLOW);
  t0 = millis();
  while (!readLimitDebounced(LIMIT_PIN_XY)) {
    stepper2.runSpeed();
    stepper3.runSpeed();
    if (millis() - t0 > HOME_TIMEOUT_MS) { Serial.println("[HOME] XY slow timeout"); return false; }
  }

  // Set step positions to reflect the known home angles at this switch pose.
  // All subsequent moveToPos() calls compute targets relative to these values.
  stepper2.setCurrentPosition(shoulderAngleToSteps(THETA1_HOME_DEG));
  stepper3.setCurrentPosition(elbowAngleToSteps(THETA2_HOME_DEG));

  Serial.println("[HOME] XY done.");
  return true;
}

bool homeRobot() {
  Serial.println("[HOME] Starting two-stage homing sequence...");
  if (!homeZTwoStage())  return false;
  if (!homeXYTwoStage()) return false;
  Serial.println("[HOME] All axes homed successfully.");
  return true;
}

